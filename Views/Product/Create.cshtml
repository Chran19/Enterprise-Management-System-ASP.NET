@model WebApp.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-plus-circle"></i> Add New Product</h1>
        <p>Fill in the form to add a new product to the inventory</p>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> Product Information
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input type="text" asp-for="Name" class="form-control" placeholder="Enter product name" required>
                            <span asp-validation-for="Name" class="invalid-feedback"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">Category <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                <option value="Electronics">Electronics</option>
                                <option value="Clothing">Clothing</option>
                                <option value="Books">Books</option>
                                <option value="Home">Home & Garden</option>
                                <option value="Sports">Sports & Outdoors</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Category" class="invalid-feedback"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label">Price ($) <span class="text-danger">*</span></label>
                                    <input type="number" asp-for="Price" class="form-control" placeholder="0.00" step="0.01" min="0" required>
                                    <span asp-validation-for="Price" class="invalid-feedback"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Stock" class="form-label">Stock Quantity <span class="text-danger">*</span></label>
                                    <input type="number" asp-for="Stock" class="form-control" placeholder="0" min="0" required>
                                    <span asp-validation-for="Stock" class="invalid-feedback"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Add Product
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="alert alert-info" role="alert">
                <h6><i class="fas fa-lightbulb"></i> Tips</h6>
                <ul style="margin-bottom: 0; padding-left: 1.5rem;">
                    <li>Use clear and descriptive product names</li>
                    <li>Select an appropriate category</li>
                    <li>Enter the current stock quantity</li>
                    <li>All fields are required</li>
                </ul>
            </div>
        </div>
    </div>
</div>
