@model List<WebApp.Models.User>

@{
    ViewData["Title"] = "User Management";
}

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-user-shield"></i> User Management</h1>
        <p>Manage registered users in the system</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-8"></div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Register")" class="btn btn-success">
                <i class="fas fa-user-plus"></i> Register New User
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> Users (@Model.Count)
        </div>
        <div class="card-body">
            @if (Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Registered</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td><strong>@user.Username</strong></td>
                                    <td>
                                        <a href="mailto:@user.Email">@user.Email</a>
                                    </td>
                                    <td><small>@user.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small></td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="@Url.Action("Delete", new { id = user.UserId })" class="btn btn-danger"
                                                   title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle"></i> No users registered yet. <a href="@Url.Action("Register")">Register
                    the first user</a>
                </div>
            }
        </div>
    </div>
</div>
