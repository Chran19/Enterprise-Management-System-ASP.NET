@model List<WebApp.Models.StudentGrade>

@{
    ViewData["Title"] = "Student Grades";
}

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-graduation-cap"></i> Student Grades</h1>
        <p>Track and manage student academic performance</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            <a href="@Url.Action("Summary")" class="btn btn-info">
                <i class="fas fa-chart-bar"></i> View Summary
            </a>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="fas fa-plus"></i> Add Grade
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> All Grades (@Model.Count)
        </div>
        <div class="card-body">
            @if (Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Student Name</th>
                                <th>Subject</th>
                                <th>Marks</th>
                                <th>Grade</th>
                                <th>Added</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var grade in Model)
                            {
                                string gradeLabel = grade.Marks >= 90 ? "A" : grade.Marks >= 80 ? "B" : grade.Marks >= 70 ? "C" : grade.Marks >= 60 ? "D" : "F";
                                string badgeClass = grade.Marks >= 90 ? "bg-success" : grade.Marks >= 80 ? "bg-info" :
                        grade.Marks >= 70 ? "bg-warning" : "bg-danger";

                                <tr>
                                    <td><strong>@grade.StudentName</strong></td>
                                    <td>@grade.Subject</td>
                                    <td><strong>@grade.Marks/100</strong></td>
                                    <td><span class="badge @badgeClass">Grade @gradeLabel</span></td>
                                    <td><small>@grade.CreatedAt.ToString("MMM dd, yyyy")</small></td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="@Url.Action("Edit", new { id = grade.GradeId })" class="btn btn-warning"
                                                   title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = grade.GradeId })" class="btn btn-danger"
                                                   title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle"></i> No grades recorded yet. <a href="@Url.Action("Create")">Add the first
                    grade</a>
                </div>
            }
        </div>
    </div>
</div>
