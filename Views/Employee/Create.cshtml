@model WebApp.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-plus-circle"></i> Add Employee</h1>
        <p>Register a new employee in the system</p>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> Employee Information
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Full Name <span
                                class="text-danger">*</span></label>
                                <input type="text" asp-for="Name" class="form-control" placeholder="Enter full name"
                                       required>
                                <span asp-validation-for="Name" class="invalid-feedback"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Department" class="form-label">Department <span
                                    class="text-danger">*</span></label>
                                    <select asp-for="Department" class="form-select" required>
                                        <option value="">-- Select Department --</option>
                                        <option value="HR">Human Resources</option>
                                        <option value="IT">Information Technology</option>
                                        <option value="Sales">Sales</option>
                                        <option value="Marketing">Marketing</option>
                                        <option value="Finance">Finance</option>
                                        <option value="Operations">Operations</option>
                                        <option value="Support">Customer Support</option>
                                    </select>
                                    <span asp-validation-for="Department" class="invalid-feedback"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Email" class="form-label">Email <span
                                                class="text-danger">*</span></label>
                                                <input type="email" asp-for="Email" class="form-control"
                                                       placeholder="name@company.com" required>
                                                <span asp-validation-for="Email" class="invalid-feedback"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label asp-for="Phone" class="form-label">Phone <span
                                                    class="text-danger">*</span></label>
                                                    <input type="tel" asp-for="Phone" class="form-control"
                                                           placeholder="+1 (555) 123-4567" required>
                                                    <span asp-validation-for="Phone" class="invalid-feedback"></span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-success">
                                                <i class="fas fa-save"></i> Add Employee
                                            </button>
                                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                                <i class="fas fa-times"></i> Cancel
                                            </a>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
